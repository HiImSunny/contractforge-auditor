# ContractForge Auditor — Backend environment variables
# Copy to .env and fill in your values before running.

# Required: Google AI Studio API key
GOOGLE_API_KEY=your_google_api_key_here

# Required: Comma-separated list of allowed frontend origins for CORS
# Example: https://contractforge-demo.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Optional: Gemini model to use (defaults to gemini-1.5-flash if not set)
GEMINI_MODEL=gemini-1.5-flash

# Optional: Lobster Trap DPI proxy URL (Veea — Track 1 integration)
# When set, all Gemini calls are routed through the proxy for deep prompt
# inspection, policy enforcement, and governance audit trail.
# Local (docker compose): http://localhost:8080
# Leave empty to call Gemini directly (no proxy).
LOBSTERTRAP_URL=
